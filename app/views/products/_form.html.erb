<%= form_with model: product, class: "space-y-5 rounded-md border border-slate-200 bg-white p-4" do |form| %>
  <% if product.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800"><%= product.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :sku, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :sku, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm", required: true %>
    </div>
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :name, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm", required: true %>
    </div>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_area :description, rows: 3, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>

  <div class="flex flex-wrap gap-5">
    <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
      <%= form.check_box :requires_gtin, class: "rounded border-slate-300 text-blue-600" %>
      GTIN
    </label>
    <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
      <%= form.check_box :requires_expiration_date, class: "rounded border-slate-300 text-blue-600" %>
      Expiration date
    </label>
    <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
      <%= form.check_box :active, class: "rounded border-slate-300 text-blue-600" %>
      Active
    </label>
  </div>

  <div class="flex gap-2">
    <%= form.submit "Save product", class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
    <%= link_to "Cancel", products_path, class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
  </div>
<% end %>
