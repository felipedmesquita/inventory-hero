<section class="space-y-5">
  <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-center">
    <div>
      <h1 class="text-2xl font-semibold">Locations</h1>
      <p class="mt-1 text-sm text-slate-500"><%= pluralize(@locations.count, "location") %></p>
    </div>
    <%= link_to "New location", new_location_path, class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
  </div>

  <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
    <% @locations.each do |location| %>
      <%= link_to location_path(location), class: "rounded-md border border-slate-200 bg-white p-4 hover:border-blue-300" do %>
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-slate-500"><%= location.code %></p>
            <h2 class="mt-1 font-semibold"><%= location.name %></h2>
          </div>
          <span class="rounded-full px-2 py-1 text-xs font-medium <%= location.inventory_counts? ? "bg-green-100 text-green-800" : "bg-slate-100 text-slate-700" %>">
            <%= location.inventory_counts? ? "Counted" : "Excluded" %>
          </span>
        </div>
        <p class="mt-4 text-2xl font-semibold"><%= location.inventory_items.count %></p>
      <% end %>
    <% end %>
  </div>
</section>
