<section class="space-y-6">
  <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-start">
    <div>
      <p class="text-sm font-medium text-slate-500"><%= @location.code %></p>
      <h1 class="mt-1 text-2xl font-semibold"><%= @location.name %></h1>
      <p class="mt-2 text-sm text-slate-500"><%= @location.inventory_counts? ? "Included in inventory counts" : "Excluded from inventory counts" %></p>
    </div>
    <%= link_to "Transfer here", new_transfer_batch_path(destination_location_id: @location.id), class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
  </div>

  <section class="rounded-md border border-slate-200 bg-white">
    <div class="border-b border-slate-200 px-4 py-3">
      <h2 class="font-semibold">Inventory</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-100">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Barcode</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Product</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @items.each do |item| %>
            <tr>
              <td class="px-4 py-3 font-medium"><%= link_to item.barcode, inventory_item_path(item), class: "text-blue-700 hover:text-blue-900" %></td>
              <td class="px-4 py-3"><%= item.product.sku %> <span class="text-slate-500"><%= item.product.name %></span></td>
              <td class="px-4 py-3"><%= status_badge(item) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
