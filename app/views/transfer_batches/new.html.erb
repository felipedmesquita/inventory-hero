<section class="max-w-3xl space-y-5">
  <div>
    <h1 class="text-2xl font-semibold">New transfer</h1>
  </div>

  <%= form_with scope: :transfer_batch, url: transfer_batches_path, class: "space-y-5 rounded-md border border-slate-200 bg-white p-4" do |form| %>
    <div>
      <%= form.label :destination_location_id, "Destination", class: "block text-sm font-medium text-slate-700" %>
      <%= form.collection_select :destination_location_id, @locations, :id, ->(location) { "#{location.code} #{location.name}" }, { selected: params[:destination_location_id], prompt: "Select location" }, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm", required: true %>
    </div>

    <div>
      <%= form.label :barcodes, "Barcodes", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_area :barcodes, rows: 10, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-sm", required: true %>
    </div>

    <div class="flex gap-2">
      <%= form.submit "Review transfer", class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
      <%= link_to "Cancel", inventory_items_path, class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
    </div>
  <% end %>
</section>
