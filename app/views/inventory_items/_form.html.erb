<%= form_with model: inventory_item, class: "space-y-5 rounded-md border border-slate-200 bg-white p-4" do |form| %>
  <% if inventory_item.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800"><%= inventory_item.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :product_id, "Product", class: "block text-sm font-medium text-slate-700" %>
      <%= form.collection_select :product_id, products, :id, ->(product) { "#{product.sku} #{product.name}" }, { selected: params[:product_id], prompt: "Select product" }, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm", required: true %>
    </div>
    <div>
      <%= form.label :location_id, "Location", class: "block text-sm font-medium text-slate-700" %>
      <%= form.collection_select :location_id, locations, :id, ->(location) { "#{location.code} #{location.name}" }, { prompt: "Select location" }, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm", required: true %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div class="rounded-md border border-slate-200 bg-slate-50 px-3 py-2">
      <p class="text-sm font-medium text-slate-700">Sequence and barcode</p>
      <p class="mt-1 text-sm text-slate-500">Generated automatically when the item is saved.</p>
    </div>
    <div>
      <%= form.label :status, class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :status, InventoryItem.statuses.keys.map { |status| [status.humanize, status] }, {}, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :gtin, "GTIN", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :gtin, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :expiration_date, class: "block text-sm font-medium text-slate-700" %>
      <%= form.date_field :expiration_date, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="flex gap-2">
    <%= form.submit "Save item", class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
    <%= link_to "Cancel", inventory_items_path, class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
  </div>
<% end %>
